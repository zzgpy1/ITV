# 运行模式: once 或 schedule
RUN_MODE=schedule
SCHEDULE_INTERVAL=21600

# 性能配置
MAX_WORKERS=10
TIMEOUT=10

# 验证配置
FFMPEG_ENABLE=true
ENABLE_RETRY=true

# IP 解析与地域筛选
ENABLE_IP_RESOLVE=true
ENABLE_REGION_FILTER=false
PREFERRED_LOCATION=
PREFERRED_ISP=

# 缓存时长（小时）
CACHE_SPEED_HOURS=24
CACHE_RAW_HOURS=24

# 输出配置
MAX_SOURCES_PER_CHANNEL=5
DEMO_MATCH_MODE=contains

# 功能开关
ENABLE_DEMO_FILTER=true
ENABLE_ALIAS=true
ENABLE_BLACKLIST=true
DATABASE_ENABLE=true

# 卡顿优化配置
MIN_LATENCY_THRESHOLD=3000      # 过滤延迟超过 3 秒的源（毫秒）
KEEP_BEST_SOURCES=3             # 每个频道保留的最佳源数量
SORT_M3U_BY_LATENCY=true        # M3U 输出按延迟排序
ENABLE_MULTI_SOURCE=true        # 启用多源备用
