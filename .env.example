# IPTV 项目环境变量（按需覆盖 config/settings 默认值）
IPTV_MAX_WORKERS=20
IPTV_TIMEOUT=8
IPTV_HTTP_TIMEOUT=8
IPTV_FFMPEG_ENABLE=true
IPTV_FFMPEG_MODE=deep
IPTV_CANDIDATE_MIN_SUCCESS=3
IPTV_CANDIDATE_MIN_SUCCESS_RATE=0.5
IPTV_CANDIDATE_MAX_LATENCY=3000
IPTV_AUTONOMOUS_MODE=true
IPTV_ENABLE_DEMO_FILTER=true
IPTV_ENABLE_ALIAS=true
IPTV_ENABLE_BLACKLIST=true
IPTV_ENABLE_JSON_OUTPUT=true
IPTV_ENABLE_LITE_VERSION=true
IPTV_ENABLE_FIXED_OPTIMIZATION=true
IPTV_MAX_SOURCES_PER_CHANNEL=3
IPTV_SLOW_SPEED_THRESHOLD=3000
IPTV_ENABLE_GITHUB_PROXY=false
